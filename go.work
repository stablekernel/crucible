go 1.25.11

toolchain go1.26.4

// Sink and source modules with a non-stdlib dependency are intentionally NOT
// listed here: the SDK-backed sink destinations (the AWS family, redis, nats,
// kafka, gcppubsub, otel, statsd) and the modules whose integration tests pull
// a driver (sink/sql and examples/sinkflow via modernc.org/sqlite); likewise the
// SDK-backed source modules (source/kafka via franz-go, source/jetstream via
// nats.go, source/cloudevents via the CloudEvents SDK) and the flagship
// examples/sourcedrive. Each is a standalone module with its own go.mod and
// replace directives, verified in CI with GOWORK=off so its vendor deps never
// enter the shared workspace's dependency graph. Only the stdlib-only sink and
// source modules join the workspace.
use (
	./cluster
	./cmd/crucible
	./durable
	./e2e
	./examples/dispatch
	./examples/fooddelivery
	./gen
	./magefiles
	./sink
	./sink/bridge
	./sink/file
	./sink/http
	./sink/prometheus
	./sink/slog
	./source
	./source/statemachine
	./state
	./state/expr
	./telemetry
	./telemetry/datadog
	./telemetry/otel
	./telemetry/slog
	./tools/docsgen
	./transport
	./wasm
)
