digraph "worker" {
    rankdir=LR;
    node [shape=box, style=rounded];
    __start [shape=point];
    __start -> "Offline";
    "Offline";
    subgraph cluster_0 {
        label="Active";
        subgraph cluster_1 {
            label="Execution";
            style=dashed;
            "Idle";
            "Busy";
            "ExecDone" [peripheries=2];
        }
        subgraph cluster_2 {
            label="Telemetry";
            style=dashed;
            "Silent";
            "Reporting";
            "TelemetryDone" [peripheries=2];
        }
    }
    "Busy" -> "ExecDone" [label="FinishExecution"];
    "Busy" -> "Idle" [label="StopWork"];
    "Idle" -> "Busy" [label="StartWork"];
    "Reporting" -> "Silent" [label="DisableReporting"];
    "Reporting" -> "TelemetryDone" [label="FinishTelemetry"];
    "Silent" -> "Reporting" [label="EnableReporting"];
    "Offline" -> "Active" [label="Activate"];
}
